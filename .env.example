# ── Backend ────────────────────────────────────────────────────────────────────

# Required: your Google OAuth 2.0 client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Required: strong random secret for JWT signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# Optional: database URL (defaults to SQLite ./dev.db)
# For PostgreSQL: postgresql+psycopg2://user:password@host/dbname
DATABASE_URL=sqlite:///./dev.db

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Set to "true" to enable dev login via X-Dev-Email header or /auth/dev-login
DEV_AUTH_ENABLED=false

# ── Email / SMTP ───────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@scorient.app

# Base URL shown in emails
APP_URL=http://localhost:5173

# ── Frontend (Vite) ────────────────────────────────────────────────────────────

# Must match GOOGLE_CLIENT_ID above
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# API base URL (empty = same origin via nginx proxy, set for local dev)
VITE_API_URL=http://localhost:8000

# Enable dev auth UI in frontend (must match DEV_AUTH_ENABLED)
VITE_DEV_AUTH=false
